# Copy this file to .env.local and replace the placeholder with your real token.
# Do not commit real Notion integration tokens.
NEXT_PUBLIC_SITE_URL=https://maxhoang.com.au

NOTION_API_KEY=secret_your_notion_integration_token
NOTION_BLOG_DATA_SOURCE_ID=bb9e4516-594b-489c-91e5-75de95deafa4
NOTION_AWARDS_DATA_SOURCE_ID=40500125-f31c-4e3f-b3c8-cdd670582dd0
NOTION_SHORT_VIDEOS_DATA_SOURCE_ID=c9ecba7a-e135-4b02-8279-93e4049610f7
NOTION_PHOTOS_DATA_SOURCE_ID=your_photos_data_source_id
NOTION_EVENTS_DATA_SOURCE_ID=43444516-1e7a-4289-a8bb-3a589c1acb29

# Optional ImageKit media storage. Add the URL endpoint to render relative
# ImageKit paths stored in Notion, for example /portfolio/cover.jpg.
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/maxhoang

# Optional credentials for future upload UI via /api/imagekit-auth.
# Keep the private key in .env.local or Vercel environment variables only.
IMAGEKIT_PUBLIC_KEY=public_your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=private_your_imagekit_private_key

# Optional alternatives if you only have database IDs.
# The app will fetch the first data source inside each database.
# NOTION_BLOG_DATABASE_ID=your_blog_database_id
# NOTION_AWARDS_DATABASE_ID=your_awards_database_id
# NOTION_SHORT_VIDEOS_DATABASE_ID=your_short_videos_database_id
# NOTION_PHOTOS_DATABASE_ID=your_photos_database_id
# NOTION_EVENTS_DATABASE_ID=your_events_database_id

# Optional cache window for Notion API reads.
# NOTION_REVALIDATE_SECONDS=300

# Obsidian GitHub vault content source. The site reads these Markdown records
# before falling back to Notion.
OBSIDIAN_VAULT_GITHUB_OWNER=HoangCuongMax
OBSIDIAN_VAULT_GITHUB_REPO=my-obsidian-vault
OBSIDIAN_VAULT_GITHUB_BRANCH=main
OBSIDIAN_VAULT_CONTENT_PATH=09 Website Database
OBSIDIAN_VAULT_REVALIDATE_SECONDS=300
# Required if the Obsidian vault repo is private. Use a fine-grained token
# with read-only Contents access to HoangCuongMax/my-obsidian-vault.
GITHUB_TOKEN=github_pat_your_read_only_token

# Contact form and newsletter notifications. Both routes send to your inbox.
CONTACT_TO_EMAIL=hoangngoccuong1414@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_NAME=Max Hoang Website
SMTP_FROM_EMAIL=your_verified_from_email
